-			}
-		};
+		if (this.productService.defaultChatAgent) {
+			deprecated[this.productService.defaultChatAgent.extensionId.toLowerCase()] = {
+				disallowInstall: true,
+				extension: {
+					id: this.productService.defaultChatAgent.chatExtensionId,
