{
  "extends": "@codingame/tsconfig",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "declaration": false,
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "target": "es2020",
    "module": "es2022",
    "lib": ["es2021", "DOM"],
    "outDir": "dist",
    "rootDir": "./",
    "paths": {
      "vs/*": ["./vscode/src/vs/*"],
      "vscode/*": ["./vscode/*"]
    }
  },
  "include": [
    "./vscode/src/vscode-dts/vscode.proposed.*.d.ts",
    "./src/**/*",
    "./rollup/**/*.ts",
    "./release.ts",
    "./scripts/*.ts"
  ]
}
